# Database
DATABASE_URL=postgresql://pea:pea_secret@localhost:5432/pea_db
POSTGRES_USER=pea
POSTGRES_PASSWORD=pea_secret
POSTGRES_DB=pea_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT & Security
JWT_SECRET=change-this-to-a-random-32-plus-character-secret-key
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=change-this-to-a-random-32-plus-character-encryption-key

# Magic Link
MAGIC_LINK_EXPIRES_IN=15

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM=assistant@example.com

# App
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Google Calendar OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/integrations/google/callback

# Microsoft 365 OAuth
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_REDIRECT_URI=http://localhost:4000/api/integrations/microsoft/callback
